{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "Antigravity",
    "description": "Your Antigravity agent on Slack",
    "background_color": "#1e1e2e"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "Antigravity",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/antigravity",
        "description": "Talk to Antigravity or run a subcommand",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands",
        "usage_hint": "[subcommand] [args]"
      },
      {
        "command": "/help",
        "description": "Show available commands and usage information",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands"
      },
      {
        "command": "/new",
        "description": "Start a new session (fresh session ID + history)",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands",
        "usage_hint": "[name]"
      },
      {
        "command": "/reset",
        "description": "Alias for /new — Start a new session (fresh session ID + history)",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands",
        "usage_hint": "[name]"
      },
      {
        "command": "/stop",
        "description": "Kill all running background processes for this session",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands"
      },
      {
        "command": "/status",
        "description": "Show workspace directory, conversation ID, and execution status",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands"
      },
      {
        "command": "/workspace",
        "description": "Set or show workspace path for this session",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands",
        "usage_hint": "[path]"
      },
      {
        "command": "/model",
        "description": "Switch the Gemini model for this session",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands",
        "usage_hint": "[model_name]"
      },
      {
        "command": "/yolo",
        "description": "Toggle YOLO mode (skip all command approvals)",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands"
      },
      {
        "command": "/sandbox",
        "description": "Toggle sandbox mode (run tasks in restricted sandbox)",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands"
      },
      {
        "command": "/version",
        "description": "Show Antigravity Agent version",
        "should_escape": false,
        "url": "https://antigravity-agent.local/slack/commands"
      }
    ],
    "assistant_view": {
      "assistant_description": "Chat with Antigravity in threads and DMs."
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "channels:read",
        "chat:write",
        "commands",
        "files:read",
        "files:write",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "assistant_thread_context_changed",
        "assistant_thread_started",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
