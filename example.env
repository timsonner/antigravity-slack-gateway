# Slack Credentials
# Bot Token (starts with xoxb-): OAuth & Permissions -> Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level Token (starts with xapp-): Settings -> Basic Information -> App-Level Tokens (requires connections:write scope)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Slack allowed users (comma-separated Slack user IDs)
SLACK_ALLOWED_USERS=

# Home Channel for proactive notifications (optional)
SLACK_HOME_CHANNEL=
SLACK_HOME_CHANNEL_NAME=general

# Optional: Antigravity Runner Configuration
# The root directory where Slack workspace projects will be created.
# Defaults dynamically to the user's home directory (e.g., C:\Users\<username> on Windows).
# ANTIGRAVITY_WORKSPACE_ROOT=/path/to/workspaces

# Model or API configuration if needed
GEMINI_API_KEY=your-gemini-api-key-here
