# Slack Credentials
# Bot Token (starts with xoxb-): OAuth & Permissions -> Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level Token (starts with xapp-): Settings -> Basic Information -> App-Level Tokens (requires connections:write scope)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Antigravity Runner Configuration
# The root directory for user workspaces
ANTIGRAVITY_WORKSPACE_ROOT=C:\Users\admin

# Model or API configuration if needed
GEMINI_API_KEY=your-gemini-api-key-here
